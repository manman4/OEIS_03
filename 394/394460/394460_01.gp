\\ G.f.: Sum_{j>=1} Product_{k>=1} (1 - delta(2*j,k) + q^(j*k)/(1-q^k)) - Product_{k>=1} (1 - delta(2*j,k) + q^((j+1)*k)/(1-q^k)), where delta(j,k) is the Kronecker delta.
my(N=60, q='q+O('q^N)); sum(j=1, N, prod(k=1, 2*N, 1-(2*j==k)+q^(j*k)/(1-q^k)) - prod(k=1, 2*N, 1-(2*j==k)+q^((j+1)*k)/(1-q^k)))
my(N=60, q='q+O('q^N)); concat(0, Vec(sum(j=1, N, prod(k=1, 2*N, 1-(2*j==k)+q^(j*k)/(1-q^k)) - prod(k=1, 2*N, 1-(2*j==k)+q^((j+1)*k)/(1-q^k)))))