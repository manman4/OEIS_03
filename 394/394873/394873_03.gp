\\ a(n) = a(n-1) + a(n-2) - 2*a(n-5) + a(n-8) + a(n-9) - a(n-10)
print("だめ");
a(n) = my(v=[0, 0, 0, 0, 0, 5, 4, 7, 9, 13, 15, 21, 24, 31, 36, 44]); if(n<15, v[n+1], a(n-1) + a(n-2) - 2*a(n-5) + a(n-8) + a(n-9) - a(n-10));
for(n=0, 35, print1(a(n), ", "));


a(n) = my(v=[0, 0, 0, 0, 0, 5, 4, 7, 9, 13, 15, 21, 24, 31, 36, 44]); if(n<16, v[n+1], a(n-1) + a(n-2) - 2*a(n-5) + a(n-8) + a(n-9) - a(n-10));
for(n=0, 35, print1(a(n), ", "));