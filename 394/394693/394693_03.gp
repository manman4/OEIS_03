\\ a(n) = n^2 * (3*n^4-6*n^3+7*n^2-4*n+1) * a(n-1) - n^2 * (n-1)^8 * (3*n^2-6*n+5) * a(n-2) + n^2 * (n-1)^8 * (n-2)^8 * a(n-3) + ((n-1)!)^6 for n > 2.
a(n) = my(v=[0, 1, 85]); if(n<3, v[n+1], n^2 * (3*n^4-6*n^3+7*n^2-4*n+1) * a(n-1) - n^2 * (n-1)^8 * (3*n^2-6*n+5) * a(n-2) + n^2 * (n-1)^8 * (n-2)^8 * a(n-3) + ((n-1)!)^6);
for(n=0, 25, print1(a(n), ", "));

