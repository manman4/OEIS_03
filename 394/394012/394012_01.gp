T(n, k) =
{
  if (k < 0 || k >= n, 0,
    if (n == 1 && k == 0, 1,
      2*(k+1)*(2*k+1) * T(n-1, k+1) +
      4*((4*k + 1)*(n-1) + 2*k^2 + k) * T(n-1, k) +
      2*(4*(n-1) + 2*k + 1)*(2*(n-1) + k - 1) * T(n-1, k-1)
    )
  )
};

kill(n);
kill(k);

for(n=1,5, for(k=0,n-1, print1(T(n,k), ", ")); print());
