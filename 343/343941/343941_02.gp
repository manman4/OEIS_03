\\ a(n) = a(n-1) + a(n-2) - a(n-4) - a(n-5) + a(n-6) for n > 14
print("だめ");
a(n) = my(v=[0, 0, 1, 0, 1, 2, 3, 3, 4, 5, 7, 8, 10, 11, 14]); if(n<14, v[n+1], a(n-1) + a(n-2) - a(n-4) - a(n-5) + a(n-6));
for(n=0, 29, print1(a(n), ", "));

