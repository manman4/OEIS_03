a000364(n) = if(n<0, 0, (2*n)! * polcoeff( 1 / cos(x + O(x^(2*n + 1))), 2*n));
for(n=0, 17, print1(a000364(n), ", "));

\\ a(n) = ((-1)^n/2) * (A000364(n) + A000364(n+1)) 
a(n) = ((-1)^n/2) * (a000364(n) + a000364(n+1));
for(n=0, 17, print1(a(n),", ")); 

a028296(n) = (-1)^n * a000364(n);
\\ (1/2) * (A028296(n) - A028296(n+1)).
