\\ a(n) = 30*a(n-1) - 400*a(n-2) + 3122*a(n-3) - 15799*a(n-4) + 54176*a(n-5) - 127512*a(n-6) + 203456*a(n-7) - 210672*a(n-8) + 127872*a(n-9) - 34560*a(n-10) for n > 14.
a(n) = my(v=[0, 0, 0, 0, 0, 0, 24, 480, 5984, 57640, 470504, 3426320, 22979920, 144970904, 872919960]); if(n<15, v[n+1], 30*a(n-1) - 400*a(n-2) + 3122*a(n-3) - 15799*a(n-4) + 54176*a(n-5) - 127512*a(n-6) + 203456*a(n-7) - 210672*a(n-8) + 127872*a(n-9) - 34560*a(n-10));
