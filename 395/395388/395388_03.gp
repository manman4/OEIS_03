a000364(n) = if(n<0, 0, (2*n)! * polcoeff( 1 / cos(x + O(x^(2*n + 1))), 2*n));
for(n=0, 17, print1(a000364(n), ", "));

\\ a(n) = (1/24) * Sum_{k=0..n} binomial(2*n,2*k) * (9*A000364(k) + 10*A000364(k+1) + A000364(k+2)).
a(n) = (1/24) * sum(k=0, n, binomial(2*n, 2*k) * (9*a000364(k) + 10*a000364(k+1) + a000364(k+2)));
for(n=0, 17, print1(a(n),", ")); 

