\\ a(n) = 7*a(n-1) - 16*a(n-2) + 12*a(n-3) for n > 5.
a(n) = my(v=[0, 0, 0, 0, 4, 24, 104]); if(n<6, v[n+1], 7*a(n-1) - 16*a(n-2) + 12*a(n-3));
for(n=0, 15, print1(a(n),", "));   
