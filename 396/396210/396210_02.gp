N=75;
M=70;

B(v) = v / (1 - v)^4;
A = B(B(B(x + x*O(x^N))));

\\ for(n=0, M, write("b396210.txt", n, " ", polcoef(A, n)));

Vec(A)

\\ G.f.: x * ((1-x) * ((1-x)^4 - x))^12 / (((1-x)^4 - x)^4 - x*(1-x)^12)^4.
Vec( A - x * ((1-x) * ((1-x)^4 - x))^12 / (((1-x)^4 - x)^4 - x*(1-x)^12)^4 )

\\ G.f.: x / ( (1-x) * (1-B(x)) * (1-B(B(x))) )^4, where B(x) = x/(1-x)^4.
A1 = B(x + x*O(x^N));
A2 = B(B(x + x*O(x^N)));
Vec(A - x/( (1-x) * (1-A1) * (1-A2) )^4)