\\ a(n) = a(n-1) + a(n-2) - 2*a(n-5) + a(n-8) + a(n-9) - a(n-10) for n > 25.
print("だめ");
a(n) = my(v=[0, 0, 0, 0, 0, 0, 0, 1, 1, 3, 4, 8, 10, 16, 19, 27, 30, 38, 44, 54, 61, 73, 82, 96, 107, 123]); if(n<25, v[n+1], a(n-1) + a(n-2) - 2*a(n-5) + a(n-8) + a(n-9) - a(n-10));
for(n=0, 39, print1(a(n), ", "));

