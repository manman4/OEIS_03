\\ a(n) = a(n-1) + a(n-2) - a(n-5) - 2*a(n-7) + a(n-9) + a(n-10) + a(n-11) + a(n-12) - 2*a(n-14) - a(n-16) + a(n-19) + a(n-20) - a(n-21) for n > 39.
a(n) = my(v=[0, 0, 0, 0, 1, 1, 1, 2, 3, 5, 7, 10, 13, 17, 22, 29, 37, 47, 59, 73, 89, 109, 131, 158, 188, 224, 263, 310, 361, 421, 486, 562, 644, 739, 841, 958, 1084, 1227, 1380, 1554]); if(n<39, v[n+1], a(n-1) + a(n-2) - a(n-5) - 2*a(n-7) + a(n-9) + a(n-10) + a(n-11) + a(n-12) - 2*a(n-14) - a(n-16) + a(n-19) + a(n-20) - a(n-21));
