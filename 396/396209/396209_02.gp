N=55;
M=50;

B(v) = v / (1 - v)^3;
A = B(B(B(x + x*O(x^N))));

\\ for(n=0, M, write("b396209.txt", n, " ", polcoef(A, n)));

Vec(A)

\\ G.f.: x * ((1-x) * ((1-x)^3 - x))^6 / (((1-x)^3 - x)^3 - x*(1-x)^6)^3.
Vec( A - x * ((1-x) * ((1-x)^3 - x))^6 / (((1-x)^3 - x)^3 - x*(1-x)^6)^3 ) 

\\ G.f.: x / ( (1-x) * (1-B(x)) * (1-B(B(x))) )^3, where B(x) = x/(1-x)^3.
A1 = B(x + x*O(x^N));
A2 = B(B(x + x*O(x^N)));
Vec(x/( (1-x) * (1-A1) * (1-A2) )^3)