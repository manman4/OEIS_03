\\ a(n) = a(n-1) + 4*a(n-2) - 4*a(n-3) - 2*a(n-4) + 2*a(n-5) - 2*a(n-6) + 2*a(n-7) + a(n-8) - a(n-9)
a(n) = my(v=[3, 6, 10, 19, 31, 58, 96, 181, 303]); if(n<10, v[n], a(n-1) + 4*a(n-2) - 4*a(n-3) - 2*a(n-4) + 2*a(n-5) - 2*a(n-6) + 2*a(n-7) + a(n-8) - a(n-9));
for(n=1, 20, print1(a(n),", "));

\\ b(n) = b*a(n-2) - 2*b(n-4) - 2*b(n-6) + b(n-8)
b(n) = my(v=[3, 4, 5, 10, 13, 28, 39, 86]); if(n<9, v[n], 4*b(n-2) - 2*b(n-4) - 2*b(n-6) + b(n-8));
for(n=1, 20, print1(b(n),", "));

