\\ a(n) = a(n-1) + a(n-2) - a(n-4) - a(n-5) + a(n-6) for n > 18.
print("だめ");
a(n) = my(v=[0, 0, 0, 0, 0, 0, 1, 1, 3, 4, 7, 8, 12, 12, 15, 17, 20, 22, 26]); if(n<18, v[n+1], a(n-1) + a(n-2) - a(n-4) - a(n-5) + a(n-6));
for(n=0, 35, print1(a(n), ", "));

