\\ G.f.: x^6/((1-3*x) * (x^6 + (1-3*x) * (1+x^3))). 
my(N=40, x='x+O('x^N)); concat([0, 0, 0, 0, 0, 0], Vec(x^6/((1-3*x)*(x^6+(1-3*x)*(1+x^3)))))

\\ Equivalently, 1/(1-3*x) - (1+x^3)/(x^6 + (1-3*x) * (1+x^3)).
my(N=40, x='x+O('x^N)); concat([0, 0, 0, 0, 0, 0], Vec(1/(1-3*x) - (1+x^3)/(x^6 + (1-3*x)*(1+x^3)) - x^6/((1-3*x)*(x^6+(1-3*x)*(1+x^3)))))