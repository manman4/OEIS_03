\\ G.f.: x^4/((1-2*x) * (x^4 + (1-2*x) * (1+x^2))). 
my(N=40, x='x+O('x^N)); concat([0, 0, 0, 0], Vec(x^4/((1-2*x)*(x^4+(1-2*x)*(1+x^2)))))

\\ Equivalently, 1/(1-2*x) - (1+x^2)/(x^4 + (1-2*x) * (1+x^2)).
my(N=40, x='x+O('x^N)); concat([0, 0, 0, 0], Vec(1/(1-2*x) - (1+x^2)/(x^4 + (1-2*x)*(1+x^2)) - x^4/((1-2*x)*(x^4+(1-2*x)*(1+x^2)))))